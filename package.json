{
  "name": "jp_ceo_and_board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI multi-agent orchestration scaffold with local prompts, skills, and extensions.",
  "scripts": {
    "lint": "bun run lint:eslint && bun run lint:types",
    "lint:eslint": "bun eslint .",
    "lint:types": "bun tsc --noEmit",
    "lint:fix": "bun eslint . --fix",
    "typecheck": "bun tsc --noEmit",
    "test": "bun test",
    "format": "bun prettier --write .",
    "format:check": "bun prettier --check .",
    "pi": "npx @mariozechner/pi-coding-agent@0.63.1",
    "pi:print": "npx @mariozechner/pi-coding-agent@0.63.1 -p"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@sinclair/typebox": "^0.34.49",
    "eslint": "^10.1.0",
    "typescript-eslint": "^8.57.2"
  }
}
